<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.VisualizzaOrarioFrame">
  <grid id="27dc6" binding="mainPanelOrario" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="20" left="20" bottom="20" right="20"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-1314568"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="be469" class="javax.swing.JLabel" binding="lblTitleOrario">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Segoe UI" size="24" style="1"/>
          <foreground color="-14796193"/>
          <text value="University Timetable Viewer"/>
        </properties>
      </component>
      <grid id="4a941" binding="filterPanelOrario" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-13812134"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="88624" class="javax.swing.JComboBox" binding="comboBox1" default-binding="true">
            <constraints/>
            <properties/>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
