<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.VisualizzaOrarioFrame">
  <grid id="27dc6" binding="mainPanelOrario" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="20" left="20" bottom="20" right="20"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-1314568"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="be469" class="javax.swing.JLabel" binding="lblTitleOrario">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Segoe UI" size="24" style="1"/>
          <foreground color="-14796193"/>
          <text value="University Timetable Viewer"/>
        </properties>
      </component>
      <grid id="4a941" binding="filterPanelOrario" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-13812134"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="88624" class="javax.swing.JComboBox" binding="cmbFilterYearOrario">
            <constraints/>
            <properties>
              <background color="-1"/>
              <font name="Segoe UI" size="14" style="0"/>
              <foreground color="-13812134"/>
              <model>
                <item value="Filter by Year"/>
                <item value="All Years"/>
                <item value="1st Year"/>
                <item value="2nd Year"/>
                <item value="3rd Year"/>
              </model>
            </properties>
          </component>
          <component id="283e4" class="javax.swing.JComboBox" binding="cmbFilterSubjectOrario">
            <constraints/>
            <properties>
              <background color="-1"/>
              <font name="Segoe UI" size="14" style="0"/>
              <foreground color="-13812134"/>
              <model>
                <item value="Filter by Subject"/>
                <item value="All Subjects"/>
              </model>
            </properties>
          </component>
          <component id="5ed05" class="javax.swing.JComboBox" binding="cmbFilterTeacherOrario">
            <constraints/>
            <properties>
              <background color="-1"/>
              <font name="Segoe UI" size="14" style="0"/>
              <foreground color="-13812134"/>
              <model>
                <item value="Filter by Teacher"/>
                <item value="All Teachers"/>
              </model>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="b8c4d" binding="scrollPanelOrario">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="900" height="320"/>
          </grid>
        </constraints>
        <properties>
          <background color="-1313281"/>
          <font name="Segoe UI" size="14" style="0"/>
          <foreground color="-13812134"/>
          <opaque value="true"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="c639a" class="javax.swing.JTable" binding="tblOrario">
            <constraints/>
            <properties>
              <background color="-1313281"/>
              <font name="Segoe UI" size="14" style="0"/>
              <foreground color="-13812134"/>
              <gridColor color="-3942421"/>
              <intercellSpacing width="-1" height="-1"/>
              <maximumSize width="-1" height="-1"/>
              <minimumSize width="-1" height="-1"/>
              <preferredScrollableViewportSize width="-1" height="-1"/>
              <preferredSize width="-1" height="-1"/>
              <rowHeight value="32"/>
              <selectionBackground color="-13812134"/>
              <selectionForeground color="-1"/>
              <showVerticalLines value="true"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <component id="a53c0" class="javax.swing.JButton" binding="btnBackOrario">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
            <preferred-size width="134" height="38"/>
          </grid>
        </constraints>
        <properties>
          <background color="-11108935"/>
          <font name="Segoe UI" size="14" style="1"/>
          <foreground color="-1"/>
          <text value="Back"/>
        </properties>
      </component>
      <component id="2248d" class="javax.swing.JButton" binding="btnCloseOrario">
        <constraints>
          <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
            <preferred-size width="134" height="38"/>
          </grid>
        </constraints>
        <properties>
          <background color="-11108935"/>
          <font name="Segoe UI" size="14" style="1"/>
          <foreground color="-1"/>
          <text value="Exit"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
