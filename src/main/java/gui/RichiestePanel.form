<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.RichiestePanel">
  <grid id="27dc6" binding="mainPanelRichieste" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="20" left="20" bottom="20" right="20"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-1314568"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="48492" class="javax.swing.JLabel" binding="lblTitleRichieste">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="1" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Segoe UI" size="24" style="1"/>
          <foreground color="-14796193"/>
          <text value="Teacher Rescheduling Requests"/>
        </properties>
      </component>
      <grid id="8a1bc" binding="tablePanelRichieste" layout-manager="GridLayoutManager" row-count="3" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="20" left="20" bottom="20" right="20"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-13812134"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="eb90f" class="javax.swing.JLabel" binding="lblSubtitleRichieste">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="3" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="Segoe UI" size="16" style="1"/>
              <foreground color="-1"/>
              <text value="Select a request from the table to process:"/>
            </properties>
          </component>
          <scrollpane id="b5246" binding="scrollPanelRichieste">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="3" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
                <preferred-size width="900" height="320"/>
              </grid>
            </constraints>
            <properties>
              <background color="-1313281"/>
              <font name="Segoe UI" size="14" style="1"/>
              <foreground color="-13812134"/>
              <opaque value="true"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="6f10d" class="javax.swing.JTable" binding="tableRichieste">
                <constraints/>
                <properties>
                  <background color="-1313281"/>
                  <font name="Segoe UI" size="14" style="0"/>
                  <foreground color="-13812134"/>
                  <gridColor color="-3942421"/>
                  <maximumSize width="-1" height="-1"/>
                  <minimumSize width="-1" height="-1"/>
                  <preferredScrollableViewportSize width="-1" height="-1"/>
                  <preferredSize width="-1" height="-1"/>
                  <rowHeight value="32"/>
                  <rowMargin value="-1"/>
                  <selectionBackground color="-13812134"/>
                  <selectionForeground color="-1"/>
                </properties>
              </component>
            </children>
          </scrollpane>
          <component id="e9e28" class="javax.swing.JButton" binding="btnApproveRichieste">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
                <preferred-size width="134" height="38"/>
              </grid>
            </constraints>
            <properties>
              <background color="-11108935"/>
              <font name="Segoe UI" size="14" style="1"/>
              <foreground color="-1"/>
              <text value="Approve Request"/>
            </properties>
          </component>
          <component id="1d260" class="javax.swing.JButton" binding="btnRejectRichieste">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
                <preferred-size width="134" height="38"/>
              </grid>
            </constraints>
            <properties>
              <background color="-11108935"/>
              <font name="Segoe UI" size="14" style="1"/>
              <foreground color="-1"/>
              <label value="Reject Request"/>
              <text value="Reject Request"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="36544" class="javax.swing.JButton" binding="btnBackRichieste">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="4" fill="0" indent="0" use-parent-layout="false">
            <preferred-size width="134" height="38"/>
          </grid>
        </constraints>
        <properties>
          <background color="-11108935"/>
          <font name="Segoe UI" size="14" style="1"/>
          <foreground color="-1"/>
          <label value="Back"/>
          <text value="Back"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
