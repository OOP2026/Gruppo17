<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.RichiestaSpostamentoPanel">
  <grid id="27dc6" binding="mainPanelSpostamento" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="20" left="20" bottom="20" right="20"/>
    <constraints>
      <xy x="20" y="20" width="588" height="400"/>
    </constraints>
    <properties>
      <background color="-1314568"/>
